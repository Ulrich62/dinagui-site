}</style><style class="wpcode-css-snippet">/* ===============================
   VARIABLES GLOBALES
================================ */
:root {
  --ai-gold-1: #E6C97A;
  --ai-gold-2: #D4AF37;
  --ai-gold-3: #B8962E;

  --ai-bg: #ffffff;
  --ai-title: #1f2d3d;
  --ai-text: #6b7280;
}

/* ===============================
   CONTENEUR
================================ */
.ai-services {
  display: flex;
  flex-wrap: wrap;
  gap: 20px;
}

/* ===============================
   CARTE
================================ */
.ai-card {
  position: relative;
  width: calc(33.333% - 14px);
  box-sizing: border-box;
  background: var(--ai-bg);
  border-radius: 16px;
  padding: 24px;
  box-shadow: 0 8px 24px rgba(0,0,0,0.08);
  transition: transform 0.3s ease;
}

.ai-card:hover {
  transform: translateY(-6px);
}

/* ===============================
   BORD GAUCHE OR -> ORANGE
================================ */
.ai-card::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0;
  width: 5px;
  height: 100%;
  background: #ff7a00;  /* Couleur unique remplacée */
  border-radius: 16px 0 0 16px;
}


/* ===============================
   ICÔNE
================================ */
.ai-card img {
  width: 42px;
  height: 42px;
  margin-bottom: 12px;
}

/* ===============================
   TITRE
================================ */
.ai-card h3 {
  margin: 0 0 8px;
  font-size: 17px;
  font-weight: 700;
  color: var(--ai-title);
}

/* ===============================
   TEXTE
================================ */
.ai-card p {
  margin: 0;
  font-size: 14px;
  line-height: 1.6;
  color: var(--ai-text);
}

/* ===============================
   RESPONSIVE
================================ */

/* Tablette */
@media (max-width: 1024px) {
  .ai-services {
    justify-content: center;
  }
  .ai-card {
    width: 100%;
    max-width: 520px;
  }
}

/* Mobile */
@media (max-width: 600px) {
  .ai-card {
    width: 100%;
  }
}
