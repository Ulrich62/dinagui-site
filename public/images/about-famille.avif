@media (max-width: 1024px) {
  .vc_row.vc_row-o-equal-height {
    display: flex !important;
    flex-direction: column;
  }

  .vc_row.vc_row-o-equal-height > .wpb_column {
    width: 100% !important;
    margin-bottom: 20px;
  }
}

